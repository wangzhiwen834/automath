# ============ LLM API Keys ============
# 按你实际使用的模型填，不用的留空即可
# DeepSeek: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# 通义千问: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=

# 智谱 GLM: https://open.bigmodel.cn/
ZHIPU_API_KEY=

# Claude (可选): https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ============ 全局配置 ============
# 工作目录，任务文件都存这里
WORKSPACE_DIR=./workspace

# 默认模型（在 config.yaml 的 model_registry 中定义的 key）
DEFAULT_MODEL=deepseek-chat
